// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum Tests {
  CFIT 
  DISC 
  MSDT 
  MBTI 
  KRAEPELIN 
  PAPIKOSTICK
}

enum Unit {
  SMP // Samamaju Prima
  MPP // makassar putra prima
  MMPP // makassar megaputra prima
  IMP //Indo mega prima
  PPH //putra prima hotel
  ACS // Aptana Citra Solusindo
  UNKNOWN
}

// Peserta

model Peserta {
  id Int @id @default(autoincrement())
  nama String
  jenisKelamin JenisKelamin
  usia Int
  pendidikanTerakhir String
  jurusan String
  unit Unit @default(UNKNOWN)

  testSession TestSession[]

  tokenId Int
  token Token @relation(fields: [tokenId], references: [id])  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Questions

model CfitQuestion {
  id        Int      @id @default(autoincrement())
  subtest   Int
  order     Int
  imagePath String        // gambar soal utama
  isPractice Boolean @default(false)

  options   CfitOption[]

  createdAt DateTime @default(now())  
  updatedAt DateTime @updatedAt

  @@unique([subtest, order, isPractice])
}

model CfitOption {
  id          Int      @id @default(autoincrement())
  questionId  Int
  label       String    // A, B, C, D, E, F
  imagePath   String    // satu gambar saja

  question    CfitQuestion @relation(fields: [questionId], references: [id])

  @@index([questionId])
}


// Questions-MSDT
model MsdtQuestion {
  id        Int      @id @default(autoincrement())
  sentences Json
  createdAt DateTime @default(now())
}

// Questions-DISC
model DiscQuestion {
  id        Int      @id @default(autoincrement())
  words     Json
  createdAt DateTime @default(now())
}

// Questions-MBTI
model MbtiQuestion {
  id        Int       @id @default(autoincrement())
  sentences Json
  createdAt DateTime  @default(now())  
}

// Questions-PAPIKOSTICK
model PapikostickQuestion {
  id        Int       @id @default(autoincrement())
  sentences Json
  createdAt DateTime  @default(now())
}

// Token

model Token {
  id Int @id @default(autoincrement())
  token String @unique
  tests Tests[]
  kuota Int
  usedCount Int @default(0)
  isActive Boolean @default(true)

  peserta Peserta[]
  
  createdAt DateTime @default(now())
  expiredAt DateTime? 
}

// jawaban

model TestSession {
  id         Int       @id @default(autoincrement())
  pesertaId Int
  token     String
  statusTest Int 

  startedAt DateTime  @default(now())
  finishedAt DateTime?

  peserta   Peserta   @relation(fields: [pesertaId], references: [id])
  attempts  TestAttempt[]

  jawabanCfit JawabanCfit[] 
  jawabanDisc JawabanDisc[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model TestAttempt {
  id         Int       @id @default(autoincrement())
  sessionId Int
  testType  String    // CFIT | MBTI | DISC | PAPI | MSDT

  startedAt DateTime  @default(now())
  finishedAt DateTime?

  session   TestSession @relation(fields: [sessionId], references: [id])
  answers   JawabanPeserta[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


model JawabanPeserta {
  id        Int    @id @default(autoincrement())
  attemptId Int
  questionId Int

  answer    Json   // format tergantung test

  attempt  TestAttempt @relation(fields: [attemptId], references: [id])

  createdAt DateTime @default(now())
}

model Admin {
  id Int @id @default(autoincrement())
  username String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JawabanCfit {
  id         Int @id @default(autoincrement())
  sessionId  Int
  subtest    Int 
  questionId Int
  answers    String[]        

  session    TestSession @relation(fields: [sessionId], references: [id])
  createdAt  DateTime @default(now())
}

model JawabanDisc {
  id          Int @id @default(autoincrement())
  sessionId   Int
  questionId  Int
  most        String
  least       String

  session     TestSession @relation(fields: [sessionId], references: [id])
  createdAt   DateTime @default(now())
}