generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Peserta {
  id                 Int           @id @default(autoincrement())
  nama               String
  jenisKelamin       JenisKelamin
  usia               Int
  pendidikanTerakhir String
  jurusan            String
  tokenId            Int
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  unit               Unit          @default(UNKNOWN)
  email              String        @default("null")
  posisi             String        @default("null")
  token              Token         @relation(fields: [tokenId], references: [id])
  testSession        TestSession[]
}

model TestSession {
  id          Int           @id @default(autoincrement())
  pesertaId   Int
  token       String
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  statusTest  Int
  jawabanCfit JawabanCfit[]
  jawabanKraepelin JawabanKraepelin[]
  jawabanDisc JawabanDisc[]
  jawabanPapikostik JawabanPapikostik[]
  
  kraepelinLog KraepelinLog[]
  attempts    TestAttempt[]
  peserta     Peserta       @relation(fields: [pesertaId], references: [id])
}

model JawabanKraepelin {
  id              Int @id @default(autoincrement())
  sessionId       Int
  columnIndex     Int
  answers         Int[]
  correctAnswers  Int
  wrongAnswers    Int
  totalAnswered   Int

  session   TestSession @relation(fields: [sessionId], references: [id])
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model KraepelinLog {
  id            Int @id @default(autoincrement())
  sessionId     Int
  timestamp     DateTime
  event         String
  fromCol       Int
  toCol         Int
  fromPair      Int
  toPair        Int

  session  TestSession  @relation(fields: [sessionId], references: [id])
  createdAt DateTime @default(now())
}

model CfitQuestion {
  id         Int          @id @default(autoincrement())
  subtest    Int
  order      Int
  imagePath  String
  isPractice Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  options    CfitOption[]

}

model CfitOption {
  id         Int          @id @default(autoincrement())
  questionId Int
  label      String
  imagePath  String
  question   CfitQuestion @relation(fields: [questionId], references: [id])

  @@index([questionId])
}

model DiscQuestion {
  id Int @id @default(autoincrement())
  questionIndex Int

  option DiscOption[]
}

model DiscOption {
  id Int @id @default(autoincrement())
  questionId Int
  sentences String
  optionIndex Int

  disc DiscQuestion @relation(fields: [questionId], references: [id])
}

model PapikostickQuestion {
  id Int @id @default(autoincrement())
  questionIndex Int
  
  option PapikostickOption[]
}

model PapikostickOption {
  id Int @id @default(autoincrement())
  questionId Int
  sentences String
  optionType Int

  papikostick PapikostickQuestion @relation(fields: [questionId], references: [id])
}


model MsdtQuestion {
  id        Int      @id @default(autoincrement())
  sentences Json
  createdAt DateTime @default(now())
}

model MbtiQuestion {
  id        Int      @id @default(autoincrement())
  sentences Json
  createdAt DateTime @default(now())
}



model Token {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  kuota     Int
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  expiredAt DateTime?
  tests     Tests[]
  peserta   Peserta[]
}

model TestAttempt {
  id         Int              @id @default(autoincrement())
  sessionId  Int
  testType   String
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  answers    JawabanPeserta[]
  session    TestSession      @relation(fields: [sessionId], references: [id])
}

model JawabanPeserta {
  id         Int         @id @default(autoincrement())
  attemptId  Int
  questionId Int
  answer     Json
  createdAt  DateTime    @default(now())
  attempt    TestAttempt @relation(fields: [attemptId], references: [id])
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JawabanCfit {
  id         Int         @id @default(autoincrement())
  sessionId  Int
  subtest    Int
  questionId Int
  createdAt  DateTime    @default(now())
  answers    String[]
  session    TestSession @relation(fields: [sessionId], references: [id])
}

model JawabanDisc {
  id            Int @id @default(autoincrement())
  sessionId     Int
  questionIndex Int
  most          Int
  least         Int

  session       TestSession @relation(fields: [sessionId], references: [id])
}

model JawabanPapikostik {
  id              Int @id @default(autoincrement())
  sessionId       Int
  questionIndex   Int
  type            Int

  session TestSession @relation(fields: [sessionId], references: [id])
}

model Testing {
  id Int @id @default(autoincrement())
  pesertaId Int
  row_number Int
  kesimpulan String
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum Tests {
  CFIT
  DISC
  MSDT
  MBTI
  KRAEPELIN
  PAPIKOSTICK
}

enum Unit {
  SMP
  MPP
  MMPP
  IMP
  PPH
  ACS
  UNKNOWN
}
